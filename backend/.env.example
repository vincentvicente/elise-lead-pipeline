# ============================================================================
# Database
# ============================================================================
# Local dev — choose one:
#   SQLite (zero setup):
#     DATABASE_URL=sqlite+aiosqlite:///./elise.db
#   Local Postgres (via docker-compose):
#     DATABASE_URL=postgresql+asyncpg://elise:elise@localhost:5432/elise
# Production (Neon): use connection string from Neon dashboard
DATABASE_URL=sqlite+aiosqlite:///./elise.db

# ============================================================================
# Enrichment APIs
# ============================================================================
# Census (free key, instant signup at https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# NewsAPI free tier (https://newsapi.org/register)
NEWS_API_KEY=

# WalkScore (https://www.walkscore.com/professional/api-sign-up.php — 24-48h approval)
WALKSCORE_API_KEY=

# FRED (https://fred.stlouisfed.org/docs/api/api_key.html — instant)
FRED_API_KEY=

# ============================================================================
# LLM
# ============================================================================
ANTHROPIC_API_KEY=
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=claude-haiku-4-5

# ============================================================================
# Alerting (Resend)
# ============================================================================
# Get key at https://resend.com (3000/month free)
RESEND_API_KEY=
ALERT_EMAIL=vincentvicenteqy@outlook.com
ALERT_FROM_ADDRESS=EliseAI Pipeline <onboarding@resend.dev>

# ============================================================================
# Application
# ============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development  # development / staging / production

# CORS for frontend
FRONTEND_URL=http://localhost:5173
